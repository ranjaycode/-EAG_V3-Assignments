# ─────────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in your actual keys
#  Both the LLM Gateway and the MCP server load from this file.
# ─────────────────────────────────────────────────────────────────

# ── LLM providers (at least ONE is required for the Gateway) ──────
# The Gateway tries providers in order: gemini, groq, cerebras,
# nvidia, github, openrouter, ollama. It skips any without a key.

GEMINI_API_KEY=your-gemini-api-key-here
# GROQ_API_KEY=your-groq-api-key-here
# CEREBRAS_API_KEY=your-cerebras-api-key-here
# NVIDIA_API_KEY=your-nvidia-api-key-here
# OPEN_ROUTER_API_KEY=your-openrouter-api-key-here
# GITHUB_ACCESS_TOKEN=your-github-personal-access-token-here
# OLLAMA_MODEL=llama3.2          # only if running Ollama locally

# ── MCP server tools ──────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ── Optional overrides ────────────────────────────────────────────
# GATEWAY_V3_PORT=8101
# LLM_GATEWAY_V3_URL=http://localhost:8101
# GEMINI_MODEL=gemini-2.5-flash
# LLM_ORDER=gemini,groq,cerebras,nvidia,github,openrouter,ollama